    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="orthT" PARENT_REF="orth@Onteri" TIER_ID="GRAIDorth">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2456" ANNOTATION_REF="a1928">
                <ANNOTATION_VALUE>poarez aˊjja stallo ja mana</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2860" ANNOTATION_REF="a2817">
                <ANNOTATION_VALUE>na puöđkajn leˊjje kanta nu pahak čierâstadat meŋŋed eked</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2861" ANNOTATION_REF="a2818">
                <ANNOTATION_VALUE>te kanta leˊjje čierastadamen</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2459" ANNOTATION_REF="a1931">
                <ANNOTATION_VALUE>pote kuöhte olma ja puotte stuora vejkkiedmijn vieǯǯamen tajt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2460" ANNOTATION_REF="a1932">
                <ANNOTATION_VALUE>poarez a`jja lokka, son vuölka tokk porramuzzan stalluj</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2461" ANNOTATION_REF="a1933">
                <ANNOTATION_VALUE>te vulkij</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2462" ANNOTATION_REF="a1934">
                <ANNOTATION_VALUE>poatta vuösta</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2463" ANNOTATION_REF="a1935">
                <ANNOTATION_VALUE>kos vulki</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2464" ANNOTATION_REF="a1936">
                <ANNOTATION_VALUE>manajt vieǯǯa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2935" ANNOTATION_REF="a2922">
                <ANNOTATION_VALUE>valte su</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2466" ANNOTATION_REF="a1938">
                <ANNOTATION_VALUE>ij</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2468" ANNOTATION_REF="a1940">
                <ANNOTATION_VALUE>te poarez aˊjja taˊjja valte su ale jallaz kantajt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2469" ANNOTATION_REF="a1941">
                <ANNOTATION_VALUE>na ittin jos kanta vulki eekeđist teärmaj te sij välte puok juökke vietest</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2470" ANNOTATION_REF="a1942">
                <ANNOTATION_VALUE>ja nu peæyaj poarez aˊjja ja kanta</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
