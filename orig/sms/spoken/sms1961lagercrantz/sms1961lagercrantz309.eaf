    <TIER LINGUISTIC_TYPE_REF="ft-engT" PARENT_REF="orth@Onteri" PARTICIPANT="Onteri" TIER_ID="ft-eng@Onteri">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2100" ANNOTATION_REF="a1928">
                <ANNOTATION_VALUE>The old man, the Stallo and the children.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3066" ANNOTATION_REF="a3051">
                <ANNOTATION_VALUE>#</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2841" ANNOTATION_REF="a2817">
                <ANNOTATION_VALUE>Well, the children in Bugøynes were badly prone to unremittingly go downhill skiing in the evenings.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2842" ANNOTATION_REF="a2818">
                <ANNOTATION_VALUE>And now the boys were skiing down the slope again.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2103" ANNOTATION_REF="a1931">
                <ANNOTATION_VALUE>There came two men and brought a big kettle, in order to get them.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2104" ANNOTATION_REF="a1932">
                <ANNOTATION_VALUE>The old man says, he would go there as food for the Stallo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3067" ANNOTATION_REF="a3052">
                <ANNOTATION_VALUE>#</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2105" ANNOTATION_REF="a1933">
                <ANNOTATION_VALUE>Thus he left.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2106" ANNOTATION_REF="a1934">
                <ANNOTATION_VALUE>He comes to towards [them].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2107" ANNOTATION_REF="a1935">
                <ANNOTATION_VALUE>— Where did you leave to?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2108" ANNOTATION_REF="a1936">
                <ANNOTATION_VALUE>— Getting the children.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2930" ANNOTATION_REF="a2922">
                <ANNOTATION_VALUE>— Take him [i.e. me]!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2110" ANNOTATION_REF="a1938">
                <ANNOTATION_VALUE>— No! We shall take these soft flesh bites!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2112" ANNOTATION_REF="a1940">
                <ANNOTATION_VALUE>Then the old man says: Take him [i.e. me] and not the foolish boys!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2113" ANNOTATION_REF="a1941">
                <ANNOTATION_VALUE>— All right, but tomorrow, when the boys head to the hill, will everyone be taken from every house.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3068" ANNOTATION_REF="a3053">
                <ANNOTATION_VALUE>#</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2114" ANNOTATION_REF="a1942">
                <ANNOTATION_VALUE>And thus the old man and the boys are saved.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Lagercrantz" LINGUISTIC_TYPE_REF="noteT" PARENT_REF="word@Onteri" PARTICIPANT="Onteri" TIER_ID="comment(Lagercrantz)@Onteri">
