    <TIER LINGUISTIC_TYPE_REF="orthT" PARENT_REF="ref@ZMN" PARTICIPANT="ZMN" TIER_ID="orth@ZMN">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a19" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>Onsim O´lssi âˊlǧǧ , Onsim O´lssi âˊlǧǧ .</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a20" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>Koozz ton Onsmâž vueˊljškueˊttiǩ , mõõn ton Onsmâž tääjškueˊttiǩ ? Suõˊnˈnʼjel joo siˊjdˈde .</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a21" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>Ǩeˊrjjnjuuˊnn jeärggaž vuäkˈklast . Ciileet joo skuõllât .</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a22" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>Ǩeˊrresnjuuˊnest kulččast .</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a23" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>Mõõn ton Onsmâž tääjškueˊttiǩ ? Koozz ton Onsmâž vueˊljškueˊttiǩ ? Suõˊnˈnʼjel joo siˊjdˈde .</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a24" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>Taatâž , mon Taatâž , Joorrevueiˊvv-Taatâš .</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a25" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>Reäǥǥam mon reäǥǥam , lååvec årra piäǥǥam . Uˊcc nieˊđe nuäǥǥam .</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a26" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>Mõõn ton Onsmâž tääjškueˊttiǩ ? Koozz ton Onsmâž vueˊljškueˊttiǩ ? Suõˊnˈnʼjel joo siˊjdˈde .</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a27" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>Suõˊnˈnʼjel joo sijddže .</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LINGUISTIC_TYPE_REF="orthT" PARENT_REF="orth@ZMN" PARTICIPANT="ZMN" TIER_ID="ft-rus@ZMN">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a28" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>Анисим Алексеич, Анисим Алексеич.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a29" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>Куда ты Анисим засобирался, что ты Анисим замутил? В сонгельский погост?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a30" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>Пестроносый бык бежит. Колокольчики переливаются звенят. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a31" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>В кереже в носу булькает.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a32" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>Что ты Анисим замутил, куда ты Анисим засобирался? В сонгельский погост.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a33" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>Татьяна, я Татьяна глупая голова.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a34" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>Плачу я плачу, к лавке ползу. Маленькую девочку качаю.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a35" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Что ты Анисим замутил, куда ты Анисим засобирался? В сонгельский погост.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a36" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>В сонгелский погостик.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LINGUISTIC_TYPE_REF="orthT" PARENT_REF="orth@ZMN" PARTICIPANT="ZMN" TIER_ID="ft-fin@ZMN">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a37" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>Anisim Aleksen poika, Anisim Aleksen poika.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>Mistä sinä, Anisim, olet tulossa? Mitä, Anisim, tulee mieleesi? Suonikylän siitaan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>Valkokuonoinen vetoporo (?) juoksee, kilisee ja kalkattaa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>Ahkion nokassa solisee (?).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>Mistä sinä, Anisim, olet tulossa? Mitä, Anisim, tulee mieleesi? Suonikylän siitaan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a38" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>Tanja, minä Tanja, hullu Tanja.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>Itken, minä itken, ryömin kehdon luo. Pientä tyttöä keinutan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Mistä sinä, Anisim, olet tulossa? Mitä, Anisim, tulee mieleesi? Suonikylän siitaan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>Suonikylän siitaan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LINGUISTIC_TYPE_REF="orthT" PARENT_REF="orth@ZMN" PARTICIPANT="ZMN" TIER_ID="ft-eng@ZMN">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a40" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>Anisim the son of Alex, Anisim the son of Alex.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a39" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>Where to are you, Anisim, taking off? What, Anisim, is coming to your mind? To the Suonikylä village. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a41" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>The trek ox White-nose runs. Jingling and ringing.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a42" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>In the sled's praw it's gurgling.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a43" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>What, Anisim, is coming to your mind? Where to are you, Anisim, taking off? To the Suonikylä village. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a44" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>Tanya, me Tanya, the nutcase-Tanya.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a45" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>I am crying, I am crying, creeping to the craddle. To craddle the little girl.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a46" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>What, Anisim, is coming to your mind? Where to are you, Anisim, taking off? To the Suonikylä village. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a47" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>To the little Suonikylä village. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LINGUISTIC_TYPE_REF="orthT" PARENT_REF="orth@ZMN" PARTICIPANT="ZMN" TIER_ID="ft-deu@ZMN">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a48" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>Anisim der Sohn von Alex, Anisim der Sohn von Alex.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a49" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>Wohin machst du dich auf den Weg, Anisim? Was kommt dir, Anisim, in den Sinn? Ins Dorf Suonikylä.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a50" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>Das Zugren Weißnase läuft. Es klingelt und schellt.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a51" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>In der Schlittenspitze gluckert es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a52" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>Was kommt dir, Anisim, in den Sinn? Wohin machst du dich auf den Weg, Anisim? Ins Dorf Suonikylä.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a53" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>Tanja, ich Tanja, die verrückte Tanja.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a54" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>Ich weine, weine, krieche zur Wiege. Wiege das kleine Mädchen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a55" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Was kommt dir, Anisim, in den Sinn? Wohin machst du dich auf den Weg, Anisim? Ins Dorf Suonikylä.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a56" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>Ins Dörfchen Suonikylä.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
